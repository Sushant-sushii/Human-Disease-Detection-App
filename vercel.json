{
  "version": 2,
  "buildCommand": "npx @tailwindcss/cli -i ./website/static/css/input.css -o ./website/static/css/output.css",
  "builds": [
    {
      "src": "index.py",
      "use": "@vercel/python",
      "config": { "runtime": "python3.11" }
    },
    {
      "src": "website/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/website/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "index.py"
    }
  ]
}